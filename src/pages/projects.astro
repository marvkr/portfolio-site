---
import Layout from "@/layouts/Layout.astro";
import { PROJECTS } from "@/config/projects";
---

<Layout
  title="Projects | Marvin Kaunda"
  description="A selection of Marvin Kaunda's side projects and hackathon builds — MCP servers, AI tools, and experimental apps."
  image="/profile-picture.webp">
  <div
    class="lg:h-screen px-6 py-6 grid grid-flow-row lg:grid-cols-2 gap-4 overflow-hidden">
    <div class="flex flex-col gap-4">
      <div
        class="sticky top-0 h-80 lg:h-full overflow-hidden rounded-3xl bg-cover bg-center"
        style="background-image: url('https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&h=600&fit=crop');">
        <div
          class="absolute w-full h-full inset-0 bg-gradient-to-br from-black/30 via-black/20 to-black/40 z-0">
        </div>
        <div
          class="absolute inset-x-0 bottom-0 left-0 h-60 bg-gradient-to-t from-black/50 to-transparent z-10">
        </div>
        <!-- H1 element for the page title -->
        <div class="absolute bottom-3 lg:bottom-5 left-5 z-20">
          <h1 class="text-white text-xl lg:text-7xl font-bold mb-2">
            <span class="animate-fade-in inline-block" style="animation-delay: 80ms;">P</span><span class="animate-fade-in inline-block" style="animation-delay: 120ms;">r</span><span class="animate-fade-in inline-block" style="animation-delay: 160ms;">o</span><span class="animate-fade-in inline-block" style="animation-delay: 200ms;">j</span><span class="animate-fade-in inline-block" style="animation-delay: 240ms;">e</span><span class="animate-fade-in inline-block" style="animation-delay: 280ms;">c</span><span class="animate-fade-in inline-block" style="animation-delay: 320ms;">t</span><span class="animate-fade-in inline-block" style="animation-delay: 360ms;">s</span>
          </h1>
        </div>
      </div>
    </div>
    <div
      class="relative py-4 flex flex-col gap-4 overflow-auto rounded-3xl border border-border bg-cover bg-scroll animate-fade-in"
      style="background-image: var(--menu-background-image); animation-delay: 480ms;">
      <div class="px-4 flex flex-col gap-4">
        {
          PROJECTS.map((project, index) => {
            const delay = `${560 + index * 80}ms`;
            const cardClass =
              "block rounded-xl border border-border/50 bg-background/80 backdrop-blur-xs p-6 animate-fade-in" +
              (project.link
                ? " hover:border-primary/60 hover:bg-background/90 transition-colors"
                : "");
            const content = (
              <>
                <div class="flex items-start justify-between gap-2 mb-2">
                  <div class="flex flex-col">
                    {(project.hackathon || project.winner) && (
                      <div class="flex flex-wrap items-center gap-2 mb-1">
                        {project.hackathon && (
                          <span class="text-xs uppercase tracking-wider text-muted-foreground font-medium">
                            {project.hackathon}
                          </span>
                        )}
                        {project.winner && (
                          <span class="inline-flex items-center gap-1 text-[10px] uppercase tracking-wider font-semibold bg-primary text-primary-foreground px-1.5 py-0.5 rounded">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class="w-3 h-3"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round">
                              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
                              <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
                              <path d="M4 22h16" />
                              <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" />
                              <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" />
                              <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" />
                            </svg>
                            Winner
                          </span>
                        )}
                      </div>
                    )}
                    <h3 class="text-lg font-semibold text-primary">
                      {project.name}
                    </h3>
                  </div>
                  {project.link && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4 text-muted-foreground shrink-0 mt-1"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round">
                      <path d="M7 17L17 7" />
                      <path d="M7 7h10v10" />
                    </svg>
                  )}
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  {project.description}
                </p>
              </>
            );
            return project.link ? (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class={cardClass}
                style={`animation-delay: ${delay};`}>
                {content}
              </a>
            ) : (
              <div class={cardClass} style={`animation-delay: ${delay};`}>
                {content}
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</Layout>
