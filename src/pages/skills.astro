---
import Layout from "@/layouts/Layout.astro";
import { TECHNOLOGIES, CORE_SKILLS, LANGUAGES } from "@/config/skills";
---

<Layout
    title="Skills | Marvin Kaunda"
    description="Explore Marvin Kaunda's technical skills including NextJS, React, TypeScript, AI development, mobile development, UI/UX design, and multilingual capabilities."
    image="/profile-picture.webp">
    <div
        class="lg:min-h-screen px-6 py-6 grid grid-flow-row lg:grid-cols-2 gap-4 overflow-hidden">
        <div class="flex flex-col gap-4">
            <div
                class="relative h-40 lg:h-full overflow-hidden rounded-3xl bg-cover bg-center animate-fade-in"
                style="background-image: url('https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&h=600&fit=crop'); animation-delay: 0ms;">
                <div
                    class="absolute w-full h-full inset-0 bg-gradient-to-br from-black/30 via-black/20 to-black/40 z-0">
                </div>
                <div
                    class="absolute inset-x-0 bottom-0 left-0 h-60 bg-gradient-to-t from-black/50 to-transparent z-10">
                </div>
                <!-- H1 element for the page title -->
                <h1
                    class="absolute bottom-3 lg:bottom-5 left-5 text-white text-3xl lg:text-7xl font-bold z-20">
                    <span class="animate-fade-in inline-block" style="animation-delay: 80ms;">Skills</span>
                </h1>
            </div>
        </div>
        <div class="relative grid grid-cols-1 gap-4">
            <div class="rounded-xl border border-border p-4 animate-fade-in" style="animation-delay: 160ms;">
