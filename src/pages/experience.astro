---
import { MenuTabs } from "@/components/MenuTabs";
import Layout from "@/layouts/Layout.astro";
import { TECHNOLOGIES, CORE_SKILLS, LANGUAGES } from "@/config/skills";
import { TechnologyBadge } from "@/components/TechnologyBadge";
---

<Layout
  title="Experience | Marvin Kaunda"
  description="Discover Marvin Kaunda's professional journey as a freelance developer and product designer, with 5+ years experience delivering 20+ projects across full-stack development and product design."
  image="/profile-picture.webp">
  <div
    class="lg:h-screen px-6 py-6 grid grid-flow-row lg:grid-cols-2 gap-4 overflow-hidden">
    <div class="flex flex-col gap-4">
      <div
        class="sticky top-0 h-80 lg:h-full overflow-hidden rounded-3xl bg-cover bg-center"
        style="background-image: url('/images/experience.webp');">
        <div
          class="absolute w-full h-full inset-0 bg-gradient-to-br from-black/30 via-black/20 to-black/40 z-0">
        </div>
        <div
          class="absolute inset-x-0 bottom-0 left-0 h-60 bg-gradient-to-t from-black/50 to-transparent z-10">
        </div>
        <!-- H1 element for the page title -->
        <div class="absolute bottom-3 lg:bottom-5 left-5 z-20">
          <h1 class="text-white text-xl lg:text-7xl font-bold mb-2">
            <span class="animate-fade-in inline-block" style="animation-delay: 80ms;">E</span><span class="animate-fade-in inline-block" style="animation-delay: 120ms;">x</span><span class="animate-fade-in inline-block" style="animation-delay: 160ms;">p</span><span class="animate-fade-in inline-block" style="animation-delay: 200ms;">e</span><span class="animate-fade-in inline-block" style="animation-delay: 240ms;">r</span><span class="animate-fade-in inline-block" style="animation-delay: 280ms;">i</span><span class="animate-fade-in inline-block" style="animation-delay: 320ms;">e</span><span class="animate-fade-in inline-block" style="animation-delay: 360ms;">n</span><span class="animate-fade-in inline-block" style="animation-delay: 400ms;">c</span><span class="animate-fade-in inline-block" style="animation-delay: 440ms;">e</span>
          </h1>
        </div>
        <!-- Contact Actions -->
        <div
          class="flex flex-row items-center gap-2 absolute right-0 bottom-0 pl-5 py-1 bg-background rounded-tl-2xl z-30">
          <!-- Border mask -->
          <svg
            class="absolute bottom-0 -left-6 h-6 w-6 fill-background"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M24 24V0C24 13.2549 13.2549 24 0 24H24Z"></path>
          </svg>
          <svg
            class="absolute right-0 -top-6 h-6 w-6 fill-background"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M24 24V0C24 13.2549 13.2549 24 0 24H24Z"></path>
          </svg>
          <!-- Resume/CV Download - HIDDEN -->
          <!--
          <a
            href="/resume.pdf"
            download="Marvin_Kaunda_Resume.pdf"
            class="h-9 w-9 p-2 relative rounded-full border border-border overflow-hidden hover:bg-foreground/10 hover:border-white/30 ease-in duration-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-full h-full fill-foreground"
              viewBox="0 0 24 24"
              ><title>file-pdf</title><g
                fill="currentColor"
                stroke-linecap="square"
                stroke-linejoin="miter"
                stroke-miterlimit="10"
                ><path
                  d="M4 9H11V2"
                  stroke="currentColor"
                  stroke-width="2"
                  fill="none"
                  stroke-linecap="butt"></path>
                <path
                  d="M4 11V9.07843C4 8.54799 4.21071 8.03929 4.58579 7.66421L9.66421 2.58579C10.0393 2.21071 10.548 2 11.0784 2H18C19.1046 2 20 2.89543 20 4V11"
                  stroke="currentColor"
                  stroke-width="2"
                  fill="none"></path>
                <path
                  d="M2 22V15H4.5C5.88071 15 7 16.1193 7 17.5V17.5C7 18.8807 5.88071 20 4.5 20H2.5"
                  stroke="currentColor"
                  stroke-width="2"
                  fill="none"></path>
                <path
                  d="M10 15V22H11.5C13.433 22 15 20.433 15 18.5C15 16.567 13.433 15 11.5 15H10Z"
                  stroke="currentColor"
                  stroke-width="2"
                  fill="none"></path>
                <path
                  d="M18 22L18 15H22M21 18.5H18.5"
                  stroke="currentColor"
                  stroke-width="2"
                  fill="none"></path></g
              ></svg
            >
          </a>
          -->
          <!-- LinkedIn Profile -->
          <a
            href="https://www.linkedin.com/in/marvinkaunda"
            target="_blank"
            class="h-9 w-9 p-2 relative rounded-full border border-border overflow-hidden hover:bg-foreground/10 hover:border-white/30 ease-in duration-100 animate-fade-in"
            style="animation-delay: 160ms;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-full h-full fill-foreground"
              viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <!-- GitHub Profile -->
          <a
            href="https://github.com/marvkr"
            target="_blank"
            class="h-9 w-9 p-2 relative rounded-full border border-border overflow-hidden hover:bg-foreground/10 hover:border-white/30 ease-in duration-100 animate-fade-in"
            style="animation-delay: 240ms;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-full h-full fill-foreground"
              viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="rounded-xl border border-border p-4 text-center animate-fade-in" style="animation-delay: 320ms;">
          <div class="text-2xl font-bold text-primary">5</div>
          <div class="text-sm text-muted-foreground">Years Experience</div>
        </div>
        <div class="rounded-xl border border-border p-4 text-center animate-fade-in" style="animation-delay: 400ms;">
          <div class="text-2xl font-bold text-primary">20+</div>
          <div class="text-sm text-muted-foreground">Projects Delivered</div>
        </div>
      </div>
    </div>
    <div
      class="relative py-4 flex flex-col gap-6 overflow-auto rounded-3xl border border-border bg-cover bg-scroll animate-fade-in"
      style="background-image: var(--menu-background-image); animation-delay: 480ms;">
      <div class="px-4 animate-fade-in" style="animation-delay: 560ms;">
        <MenuTabs client:load />
      </div>
      <div class="px-4 pb-4 flex flex-col gap-4">
        <div
          class="rounded-xl border border-border/50 bg-background/80 backdrop-blur-xs p-6 animate-fade-in"
          style="animation-delay: 640ms;">
          <h3 class="text-lg font-semibold mb-4 text-primary">Education</h3>
          <div class="space-y-4 text-sm text-muted-foreground">
            <div class="animate-fade-in" style="animation-delay: 720ms;">
              <div class="font-medium text-foreground">
                Master in International Management & Strategy
              </div>
              <div>Vlerick Business School, Brussels (2021)</div>
            </div>
            <div class="animate-fade-in" style="animation-delay: 800ms;">
              <div class="font-medium text-foreground">
                Master in Business Engineering
              </div>
              <div>Solvay Business School, Brussels (2018-2020)</div>
            </div>
            <div class="animate-fade-in" style="animation-delay: 880ms;">
              <div class="font-medium text-foreground">Exchange Program</div>
              <div>Carleton University, Ottawa, Ontario (Fall 2019)</div>
            </div>
            <div class="animate-fade-in" style="animation-delay: 960ms;">
              <div class="font-medium text-foreground">
                Bachelor in Business Engineering
              </div>
              <div>Solvay Business School, Brussels (2015-2018)</div>
            </div>
          </div>
        </div>

        <div
          class="rounded-xl border border-border/50 bg-background/80 backdrop-blur-xs p-6 animate-fade-in"
          style="animation-delay: 720ms;">
          <h3 class="text-lg font-semibold mb-4 text-primary">Technologies</h3>
          <div class="flex flex-wrap gap-2">
            {
              Object.values(TECHNOLOGIES).map((tech) => (
                <TechnologyBadge technology={tech} />
              ))
            }
          </div>
        </div>

        <div
          class="rounded-xl border border-border/50 bg-background/80 backdrop-blur-xs p-6 animate-fade-in"
          style="animation-delay: 800ms;">
          <h3 class="text-lg font-semibold mb-4 text-primary">Core Skills</h3>
          <div class="flex flex-wrap gap-2">
            {
              CORE_SKILLS.map((skill) => (
                <span class="text-xs bg-secondary text-secondary-foreground px-2 py-1 rounded w-fit">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>

        <div
          class="rounded-xl border border-border/50 bg-background/80 backdrop-blur-xs p-6 animate-fade-in"
          style="animation-delay: 880ms;">
          <h3 class="text-lg font-semibold mb-4 text-primary">Languages</h3>
          <div class="flex flex-wrap gap-2">
            {
              LANGUAGES.map((language) => (
                <span class="text-xs bg-secondary text-secondary-foreground px-2 py-1 rounded w-fit">
                  {language}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
