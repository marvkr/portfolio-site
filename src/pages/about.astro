---
import { RatingCard } from "@/components/RatingCard";
import Layout from "@/layouts/Layout.astro";
import { TestimonialCard} from "@/components/TestimonialCard"
---

<Layout title="About">
    <div class="lg:min-h-screen px-6 py-6 grid grid-flow-row lg:grid-cols-2 gap-4 overflow-hidden">
        <div class="flex flex-col gap-4">
            <div class="relative h-40 lg:h-full overflow-hidden rounded-3xl">
                <img class="absolute w-full h-full inset-0 object-cover z-0" src="./images/menu-page-image.webp" alt="plate of sushi">
                <div class="absolute inset-x-0 bottom-0 left-0 h-60 bg-gradient-to-t from-black to-transparent z-10"></div>
                        <!-- H1 element for the restaurant name -->
                         <h1 class="absolute bottom-3 lg:bottom-5 left-5 text-white text-3xl lg:text-7xl font-bold z-20">About</h1>
                    </div>
            <div class="grid grid-cols-2 gap-4">
                <RatingCard rating={4.7} platform="Google" logo="/google-logo.svg"/>
                <RatingCard rating={4.7} platform="TripAdvisor" logo="/tripadvisor-logo.svg"/>
            </div>
        </div>
		<div class="relative grid grid-row gap-4">
            <div class="grid grid-rows-1 lg:grid-cols-2 gap-4">
                <div class="rounded-xl border border-border p-10 lg:p-4">
                    <p class="font-caveat">
                    Born in Tokyo, my passion for Japanese cuisine took root under the guidance of sushi masters on the vibrant streets of my hometown.
                    <br/><br/>
                    As my journey expanded across borders, I blended traditional techniques with global influences. This amalgamation found its home in Brussels, giving rise to Hiroshi's Omakase—a place where every dish tells a story, a synthesis of Japanese precision and international creativity.
                    </p>
