---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Menu">
    <div class="min-h-screen px-6 py-6 grid grid-flow-row sm:grid-cols-2 gap-4">
        <div class="relative h-80 sm:h-full overflow-hidden rounded-3xl">
            <img class="absolute w-full h-full inset-0 object-cover z-0" src="./images/menu-page-image.webp" alt="plate of sushi">
            <div class="absolute inset-x-0 bottom-0 left-0 h-60 bg-gradient-to-t from-black to-transparent z-10"></div>
			<!-- H1 element for the restaurant name -->
			 <h1 class="absolute bottom-3 sm:bottom-5 left-5 text-white text-xl sm:text-7xl font-bold z-20">Menu</h1>
			 <!-- CTA -->
			 <div class="flex flex-row items-center gap-2 absolute right-0 bottom-0 pl-5 py-1 bg-background rounded-tl-2xl z-30">
				<!-- Border mask -->
				<svg  class="absolute bottom-0 -left-6 h-6 w-6 fill-background" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path fill-rule="evenodd" clip-rule="evenodd" d="M24 24V0C24 13.2549 13.2549 24 0 24H24Z"/>
				</svg>
				<svg  class="absolute right-0 -top-6 h-6 w-6 fill-background" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path fill-rule="evenodd" clip-rule="evenodd" d="M24 24V0C24 13.2549 13.2549 24 0 24H24Z"/>
				</svg>
				<!-- Instagram icon -->
				<div class="h-9 w-9 p-2 relative rounded-full border border-border overflow-hidden hover:bg-foreground/10 hover:border-white/30 ease-in duration-100">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full stroke-foreground" viewBox="0 0 24 24"><g fill="none"  stroke-width="1.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 16a4 4 0 1 0 0-8a4 4 0 0 0 0 8Z"/>
						<path d="M3 16V8a5 5 0 0 1 5-5h8a5 5 0 0 1 5 5v8a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5Z"/>
						<path stroke-linecap="round" stroke-linejoin="round" d="m17.5 6.51l.01-.011"/></g>
					</svg>
				</div>
				<!-- Tik Tok icon -->
				<div class="h-9 w-9 p-2 relative rounded-full border border-border overflow-hidden hover:bg-foreground/10 hover:border-white/30 ease-in duration-100">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
						<path fill="currentColor" d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6c0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64c0 3.33 2.76 5.7 5.69 5.7c3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48z"/>
					</svg>
				</div>
				<!-- Facebook icon -->
				<div class="h-9 w-9 p-2 relative rounded-full border border-border overflow-hidden hover:bg-foreground/10 hover:border-white/30 ease-in duration-100">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
						<path fill="currentColor" d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
					</svg>
				</div>
        </div>
        <div class="relative h-80 sm:h-full overflow-hidden rounded-3xl">
        </div>
    </div>
</Layout>